generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  nombres          String
  apellidos        String
  password         String
  fechaNacimiento  DateTime?
  moneda           String        @default("COP")
  isDeleted        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  categorias       Categoria[]
  transacciones    Transaccion[]
}

model Categoria {
  id           Int           @id @default(autoincrement())
  nombre       String
  descripcion  String?
  tipo         String        @default("EGRESO") // INGRESO or EGRESO
  icono        String?
  usuarioId    Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  transacciones Transaccion[]

  @@unique([usuarioId, nombre])
}

model TipoTransaccion {
  id           Int           @id @default(autoincrement())
  nombre       String        @unique // e.g. "INGRESO", "EGRESO"
  descripcion  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transacciones Transaccion[]
}

model Periodo {
  id           Int           @id @default(autoincrement())
  nombre       String        @unique // e.g. "2025-06"
  fechaInicio  DateTime
  fechaFin     DateTime
  estado       String        @default("ACTIVO")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transacciones Transaccion[]
}

model Transaccion {
  id                Int             @id @default(autoincrement())
  monto             Float
  descripcion       String?
  fecha             DateTime
  usuarioId         Int
  categoriaId       Int
  tipoTransaccionId Int
  periodoId         Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  usuario           Usuario         @relation(fields: [usuarioId], references: [id])
  categoria         Categoria       @relation(fields: [categoriaId], references: [id])
  tipoTransaccion   TipoTransaccion @relation(fields: [tipoTransaccionId], references: [id])
  periodo           Periodo         @relation(fields: [periodoId], references: [id])
}
