generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// SPRINT 1 MODELS
// =============================================

model Usuario {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  nombres          String
  apellidos        String
  password         String
  fechaNacimiento  DateTime?
  moneda           String        @default("COP")
  isDeleted        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  categorias       Categoria[]
  transacciones    Transaccion[]
  presupuestos     Presupuesto[]  // [HU-05] A user manages their own budgets
}

model Categoria {
  id           Int            @id @default(autoincrement())
  nombre       String
  descripcion  String?
  tipo         String         @default("EGRESO") // "INGRESO" or "EGRESO"
  icono        String?
  usuarioId    Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  usuario      Usuario        @relation(fields: [usuarioId], references: [id])
  transacciones Transaccion[]
  presupuestos  Presupuesto[]

  @@unique([usuarioId, nombre])
}

model TipoTransaccion {
  id           Int           @id @default(autoincrement())
  nombre       String        @unique // "INGRESO" or "EGRESO"
  descripcion  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transacciones Transaccion[]
}

model Periodo {
  id           Int           @id @default(autoincrement())
  nombre       String        @unique // e.g. "2025-06"
  fechaInicio  DateTime
  fechaFin     DateTime
  estado       String        @default("ACTIVO")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transacciones Transaccion[]
  presupuestos  Presupuesto[] // [HU-05] Budgets are linked to a specific period
}

model Transaccion {
  id                Int             @id @default(autoincrement())
  monto             Float
  descripcion       String?
  fecha             DateTime
  usuarioId         Int
  categoriaId       Int
  tipoTransaccionId Int
  periodoId         Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  usuario           Usuario         @relation(fields: [usuarioId], references: [id])
  categoria         Categoria       @relation(fields: [categoriaId], references: [id])
  tipoTransaccion   TipoTransaccion @relation(fields: [tipoTransaccionId], references: [id])
  periodo           Periodo         @relation(fields: [periodoId], references: [id])
  alerta            Alerta?         // [HU-06] One transaction can optionally trigger one alert
}

// =============================================
// SPRINT 2 MODELS
// =============================================

// [HU-05] Presupuesto: Budget cap per user/category/period combination.
// BREAKING CHANGE from previous implementation:
//   - Added usuarioId: budgets are now user-owned (required by HU-05 acceptance criteria)
//   - Added periodoId: budgets are tied to a Periodo (not raw mes/anio) for consistency
//   - Kept mes/anio as computed helpers for calendar-based aggregation
//   - Unique constraint now includes usuarioId: prevents same user from duplicating
model Presupuesto {
  id            Int       @id @default(autoincrement())
  usuarioId     Int
  categoriaId   Int
  periodoId     Int
  montoLimite   Float     // Max spending allowed for this category in this period
  mes           Int       // Calendar month (1–12), derived from Periodo.fechaInicio
  anio          Int       // Calendar year, derived from Periodo.fechaInicio
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  usuario       Usuario   @relation(fields: [usuarioId], references: [id])
  categoria     Categoria @relation(fields: [categoriaId], references: [id])
  periodo       Periodo   @relation(fields: [periodoId], references: [id])
  alertas       Alerta[]

  // [UNIQUE] One budget per user+category+period — prevents duplicate plans
  @@unique([usuarioId, categoriaId, periodoId])
}

// [HU-06] Alerta: Records budget warning/exceeded events for audit and display.
// tipoAlerta: "ADVERTENCIA" (80–100%) or "EXCEDIDO" (>100%)
model Alerta {
  id              Int          @id @default(autoincrement())
  presupuestoId   Int
  transaccionId   Int          @unique
  mensaje         String
  tipoAlerta      String       @default("EXCEDIDO") // "ADVERTENCIA" or "EXCEDIDO"
  porcentajeUso   Float        // Percentage at time of alert (e.g. 85.5 or 110.0)
  montoGastado    Float
  montoLimite     Float
  createdAt       DateTime     @default(now())

  presupuesto     Presupuesto  @relation(fields: [presupuestoId], references: [id])
  transaccion     Transaccion  @relation(fields: [transaccionId], references: [id])
}
